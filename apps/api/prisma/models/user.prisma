enum Role {
  TRAVELER
  ADMIN
}

model User {
  id          Int       @id @default(autoincrement())
  phoneNumber String    @unique
  password    String
  name        String
  role        Role      @default(TRAVELER)
  verified    Boolean   @default(false)
  bookings    Booking[]
  createdAt   DateTime  @default(now())
}
