model Booking {
    id            Int      @id @default(autoincrement())
    tourId        Int
    tour          Tour     @relation(fields: [tourId], references: [id])
    userId        Int
    user          User     @relation(fields: [userId], references: [id])
    passengerName String
    phoneNumber   String
    seatsBooked   Int
    createdAt     DateTime @default(now())
}
